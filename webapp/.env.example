# TowerScout Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# MAP PROVIDER API KEYS (REQUIRED)
# =============================================================================

# Google Maps API Key
# Required for Google Maps satellite imagery
# Get your key at: https://developers.google.com/maps/documentation/javascript/get-api-key
# Required APIs: Maps JavaScript API, Maps Static API, Places API
GOOGLE_API_KEY=your_google_maps_api_key_here

# Bing Maps API Key (Legacy provider - being deprecated)
# Required for Bing Maps satellite imagery
# Get your key at: https://docs.microsoft.com/en-us/bingmaps/getting-started/bing-maps-dev-center-help/getting-a-bing-maps-key
# NOTE: Bing Maps will be replaced by Azure Maps in future versions
BING_API_KEY=your_bing_maps_api_key_here

# Azure Maps Subscription Key (Recommended provider)
# Required for Azure Maps satellite imagery - Modern, reliable, cost-effective
# 
# === INDIVIDUAL/DEVELOPMENT USAGE ===
# Get your key at: https://portal.azure.com -> Create Azure Maps Account -> Keys and Endpoint
# Use the Primary Key from your Azure Maps Account
#
# === ENTERPRISE USAGE ===
# For enterprise deployments, consider Azure Active Directory authentication
# This subscription key method works for both individual and enterprise accounts
# Enterprise customers may want to use Azure Key Vault (see TASK-009)
#
# === SUBSCRIPTION KEY MANAGEMENT ===
# Primary Key: Use for production
# Secondary Key: Use for key rotation without downtime
# Regenerate keys periodically for security
AZURE_MAPS_SUBSCRIPTION_KEY=your_azure_maps_subscription_key_here

# =============================================================================
# GEOCODING CONFIGURATION (OPTIONAL)
# =============================================================================

# Address Lookup Settings
# Server-side geocoding for detected cooling towers provides building addresses
# Both providers are optional - if neither is configured, coordinate fallback is used

# Google Geocoding API (Uses same key as Google Maps above)
# Additional quota available for geocoding beyond map tiles
# If GOOGLE_API_KEY is set above, it will be used for geocoding automatically

# Azure Maps Search API (Uses same key as Azure Maps above)  
# Reverse geocoding service included with Azure Maps subscription
# If AZURE_MAPS_SUBSCRIPTION_KEY is set above, it will be used for geocoding automatically

# Geocoding Rate Limiting (requests per minute per session)
# Adjust based on your API quotas and usage patterns
# Default: 30 requests per minute per session
GEOCODING_RATE_LIMIT=30

# Spatial Clustering Radius (meters)
# Groups nearby detections to reduce API calls
# Default: 50 meters - detections within this radius share the same address
# Set to 0 to disable clustering (not recommended - increases API usage)
GEOCODING_CLUSTERING_RADIUS=50

# Geocoding Cache Configuration (Optional)
# Redis URL for enhanced caching - improves performance and reduces API calls
# If not set, file-based caching will be used
# Example: redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# Cache Expiration (hours)
# How long to keep geocoded addresses in cache
# Default: 24 hours
GEOCODING_CACHE_HOURS=24

# =============================================================================
# FLASK APPLICATION CONFIGURATION
# =============================================================================

# Flask Secret Key (REQUIRED for sessions)
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_flask_secret_key_here

# Flask Environment (development/staging/production)
FLASK_ENV=development

# Flask Debug Mode (true/false)
# WARNING: Never set to true in production
FLASK_DEBUG=false

# =============================================================================
# TOWERSCOUT APPLICATION SETTINGS
# =============================================================================

# Default Map Provider (google/bing/azure)
# Recommended: azure (modern, cost-effective, reliable)
# Alternative: google (established, high-quality imagery)
# Deprecated: bing (being phased out)
DEFAULT_MAP_PROVIDER=azure

# Maximum tiles per session (adjust based on server capacity)
MAX_TILES_SESSION=100000

# Model Parameters Directory (relative to webapp/)
MODEL_PARAMS_DIR=model_params

# Upload Directory (for temporary files)
UPLOAD_DIR=uploads

# Model upload is disabled by default for first-release local packaging because
# PyTorch .pt/.pth files are trusted code artifacts. Leave disabled for normal
# users. Set to true only for trusted local-admin/developer workflows.
TOWERSCOUT_ENABLE_MODEL_UPLOAD=false

# Maximum accepted HTTP request body size. Keep aligned with
# TowerScoutValidator.MAX_FILE_SIZE and the Waitress max_request_body_size
# configured by the application entrypoint.
TOWERSCOUT_MAX_REQUEST_BODY_BYTES=52428800

# =============================================================================
# AZURE MAPS ADVANCED CONFIGURATION (OPTIONAL)
# =============================================================================

# Azure Maps Authentication Method (subscription_key/aad/sas)
# subscription_key: Use subscription key (default, recommended for most users)
# aad: Use Azure Active Directory (enterprise only, requires additional setup)
# sas: Use Shared Access Signature tokens (advanced scenarios)
AZURE_MAPS_AUTH_METHOD=subscription_key

# Azure Maps Tileset (microsoft.imagery is recommended for cooling tower detection)
# Options: microsoft.imagery, microsoft.base.road, microsoft.base.hybrid
AZURE_MAPS_TILESET=microsoft.imagery

# Azure Maps Region (optional, auto-detected if not specified)
# Use this to force a specific region for data residency requirements
# Examples: eastus, westeurope, southeastasia
# AZURE_MAPS_REGION=eastus

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Application Host (default: localhost)
HOST=localhost

# Application Port (default: 5000)
PORT=5000

# Session Timeout (minutes)
SESSION_TIMEOUT=30

# Enable detailed logging (true/false)
DETAILED_LOGGING=false

# Log Level (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# HTTPS Only Cookies (true/false) - Set to true in production
SECURE_COOKIES=false

# Same-Site Cookie Policy (Strict/Lax/None)
COOKIE_SAMESITE=Lax

# Session Cookie Name
SESSION_COOKIE_NAME=towerscout_session

# Local troubleshooting only. Disables TLS certificate verification for provider
# validation/geocoding paths when set to true/1/yes/on. Never use as a normal
# supported runtime setting.
TOWERSCOUT_ALLOW_INSECURE_TLS=false

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable development features (true/false)
DEVELOPMENT_MODE=true

# Skip ML model loading for faster development startup (true/false)
SKIP_MODEL_LOADING=false

# Mock API calls for development without consuming API quota (true/false)
MOCK_API_CALLS=false
