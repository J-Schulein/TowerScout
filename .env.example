# TowerScout Compose runtime template.
# Provider API keys are normally entered in the Setup Wizard and persisted in
# the towerscout_config volume, not stored in this file.

TOWERSCOUT_IMAGE=ghcr.io/j-schulein/towerscout:latest
TOWERSCOUT_IMAGE_DIGEST=
TOWERSCOUT_PORT=5000
TOWERSCOUT_CONTAINER_ENGINE=
TOWERSCOUT_MAX_REQUEST_BODY_BYTES=52428800
TOWERSCOUT_VERIFY_ASSET_HASHES=0

# Prefer a trusted combined CA bundle when a proxy or endpoint tool inspects TLS.
# Example container path after running scripts/import-tls-ca.cmd:
# REQUESTS_CA_BUNDLE=/app/webapp/config/certs/towerscout-ca-bundle.pem
# SSL_CERT_FILE=/app/webapp/config/certs/towerscout-ca-bundle.pem
REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

# Last-resort provider-key validation workaround only. Do not use as the normal
# release setting; provider requests skip TLS verification when enabled.
TOWERSCOUT_ALLOW_INSECURE_TLS=0
YOLO_CONFIG_DIR=/app/webapp/cache/ultralytics

# Developer/support builds can override the CPU PyTorch wheel index.
PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
